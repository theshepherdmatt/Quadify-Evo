[Unit]
Description=Main Quadify Service
After=network.target volumio.service
Wants=volumio.service

[Service]
Type=simple
User=volumio
WorkingDirectory=/data/plugins/system_hardware/quadify/quadifyapp
ExecStart=/usr/bin/python3 /data/plugins/system_hardware/quadify/quadifyapp/src/main.py
ExecStop=/usr/bin/python3 /data/plugins/system_hardware/quadify/quadifyapp/service/reset_oled_gpio.py
Restart=on-failure
Environment="PYTHONUNBUFFERED=1"
TimeoutStopSec=10
KillSignal=SIGTERM
KillMode=mixed

[Install]
WantedBy=multi-user.target

